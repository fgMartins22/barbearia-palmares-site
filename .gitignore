# ============================================================
#  .gitignore — Barbearia Palmares (Angular)
#  Mantém no Git apenas o necessário para dev, build e deploy.
# ============================================================

# Dependências
node_modules/

# Build
dist/
.angular/
out-tsc/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Cache
.cache/
.parcel-cache/
.eslintcache

# IDEs
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp

# Sistema operacional
.DS_Store
Thumbs.db

# Arquivos temporários
tmp/
temp/
*.tmp

# Variáveis de ambiente
.env
.env.local
.env.development
.env.production

# Cobertura de testes
coverage/

# Arquivos gerados automaticamente
*.tsbuildinfo

# Vercel
.vercel/
